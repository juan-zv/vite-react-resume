{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(?i).*text/markdown.*"
        }
      ],
      "destination": "/index.md"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(?i).*text/markdown.*"
        }
      ],
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "</index.md>; rel=\"alternate\"; type=\"text/markdown\""
        }
      ]
    }
  ]
}
